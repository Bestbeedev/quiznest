// Prisma schema — Phase 1 (Foundation): organizations, users, membership/RBAC.
// Phase 3 (Quiz & Questions) added below. Participants/results/etc. remain for later phases
// (see cahier des charges).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum MemberRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  MANAGER
  EDITOR
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model Organization {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  logo        String?
  banner      String?

  country String?
  city    String?
  address String?
  phone   String?
  email   String?
  website String?

  timezone String @default("UTC")
  language String @default("fr")
  currency String @default("XOF")

  subdomain    String? @unique
  customDomain String? @unique @map("custom_domain")

  settings Json               @default("{}")
  status   OrganizationStatus @default(TRIAL)

  members OrganizationMember[]
  quizzes Quiz[]

  subscription Subscription?
  payments     Payment[]
  invoices     Invoice[]
  featureUsage FeatureUsage[]
  wallet             Wallet?
  couponRedemptions  CouponRedemption[]
  addOnPurchases     OrganizationAddOn[]
  passes             OrganizationPass[]
  auditLogs    AuditLog[]
  invitations  Invitation[]
  apiKeys      ApiKey[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([status])
  @@index([createdAt])
  @@map("organizations")
}

model User {
  id            String  @id @default(cuid())
  // `name` is required by Better Auth's core User model; firstName/lastName
  // remain our own domain fields (kept in sync at signup).
  name          String
  firstName     String  @map("first_name")
  lastName      String  @map("last_name")
  email         String  @unique
  emailVerified Boolean @default(false) @map("email_verified")
  phone         String?

  image     String?
  lastLogin DateTime? @map("last_login")
  lastIp    String?   @map("last_ip")

  timezone    String     @default("UTC")
  language    String     @default("fr")
  status      UserStatus @default(ACTIVE)
  preferences Json       @default("{}")

  twoFAEnabled Boolean @default(false) @map("two_fa_enabled")
  twoFASecret  String? @map("two_fa_secret")

  /// Platform-level role — grants access to the /admin space, independent of any
  /// organization membership. Not exposed anywhere in the UI yet; must be set directly
  /// in the database for the first super admin.
  isSuperAdmin Boolean @default(false) @map("is_super_admin")

  memberships     OrganizationMember[]
  quizzes         Quiz[]
  auditLogs       AuditLog[]
  sentInvitations Invitation[]
  createdApiKeys  ApiKey[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  sessions Session[]
  accounts Account[]

  @@index([status])
  @@map("users")
}

model OrganizationMember {
  id             String     @id @default(cuid())
  userId         String     @map("user_id")
  organizationId String     @map("organization_id")
  role           MemberRole @default(VIEWER)
  permissions    Json       @default("[]")

  invitedBy        String?          @map("invited_by")
  invitationStatus InvitationStatus @default(ACCEPTED) @map("invitation_status")

  joinedAt DateTime @default(now()) @map("joined_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

/// A pending invite to join an organization, keyed by email rather than
/// userId — the invitee may not have an account yet. No email is sent (no
/// email provider is wired in this project); the invite is a shareable link
/// with a token, accepted at /invite/[token].
model Invitation {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  email          String
  role           MemberRole       @default(VIEWER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedBy      String           @map("invited_by")
  expiresAt      DateTime         @map("expires_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@map("invitations")
}

/// Storage/management only — no API route currently authenticates requests
/// with these keys (no public API exists yet, see roadmap Phase 8). Only the
/// hash is stored; the full key is shown once at creation time.
model ApiKey {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  name           String
  keyPrefix      String    @map("key_prefix")
  keyHash        String    @map("key_hash")
  lastUsedAt     DateTime? @map("last_used_at")
  createdBy      String    @map("created_by")
  revokedAt      DateTime? @map("revoked_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@map("api_keys")
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

model Quiz {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  authorId       String @map("author_id")

  title       String
  slug        String
  description String?

  timeLimit       Int?    @map("time_limit")
  passingScore    Int     @default(50) @map("passing_score")
  attempts        Int     @default(1)
  randomOrder     Boolean @default(false) @map("random_order")
  shuffleChoices  Boolean @default(false) @map("shuffle_choices")
  fullscreen      Boolean @default(false)
  accessCode      String? @unique @map("access_code")
  showCorrections Boolean @default(true) @map("show_corrections")

  status      QuizStatus @default(DRAFT)
  publishedAt DateTime?  @map("published_at")
  archivedAt  DateTime?  @map("archived_at")
  openDate    DateTime?  @map("open_date")
  closeDate   DateTime?  @map("close_date")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  questions    Question[]
  participants Participant[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("quizzes")
}

model Question {
  id     String @id @default(cuid())
  quizId String @map("quiz_id")

  title       String
  type        QuestionType       @default(SINGLE_CHOICE)
  difficulty  QuestionDifficulty @default(MEDIUM)
  order       Int
  points      Int                @default(1)
  timeLimit   Int?               @map("time_limit")
  hint        String?
  explanation String?

  /// Free-text subject grouping (e.g. "Mathématiques") — no separate category
  /// taxonomy/CRUD exists yet, this is deliberately a plain field until one does.
  category String?
  tags     String[] @default([])

  quiz    Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  choices QuestionChoice[]
  answers Answer[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([quizId, order])
  @@map("questions")
}

model QuestionChoice {
  id         String @id @default(cuid())
  questionId String @map("question_id")

  text      String
  order     Int
  isCorrect Boolean @default(false) @map("is_correct")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, order])
  @@map("question_choices")
}

enum ParticipantStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model Participant {
  id     String @id @default(cuid())
  quizId String @map("quiz_id")

  name  String
  email String?

  attempt    Int               @default(1)
  status     ParticipantStatus @default(IN_PROGRESS)
  score      Int               @default(0)
  percentage Float             @default(0)
  passed     Boolean           @default(false)

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  timeSpent   Int?      @map("time_spent")

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([quizId, status])
  @@index([quizId, email])
  @@map("participants")
}

model Answer {
  id            String   @id @default(cuid())
  participantId String   @map("participant_id")
  questionId    String   @map("question_id")
  choiceIds     String[] @map("choice_ids")

  isCorrect Boolean @default(false) @map("is_correct")
  score     Int     @default(0)
  /// Seconds spent on this question — null for answers submitted before this
  /// was tracked, or if the client didn't report it. Not backfillable.
  timeSpent Int?    @map("time_spent")

  createdAt DateTime @default(now()) @map("created_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([participantId, questionId])
  @@map("answers")
}

// --- Billing (Phase 7 groundwork) ---------------------------------------
// Minimal schema to back the super admin dashboard (subscriptions/payments/
// revenue). No payment provider is wired yet — Payment rows will only start
// appearing once FedaPay integration lands; Subscription rows exist from day
// one because every organization is auto-enrolled on the Free plan at creation.

enum PlanInterval {
  MONTH
  YEAR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Plan {
  id       String       @id @default(cuid())
  name     String
  slug     String       @unique
  /// Whole-unit amount in `currency` (XOF has no minor unit). Null = pricing not yet defined (sur devis).
  price    Int?
  currency String       @default("XOF")
  interval PlanInterval @default(MONTH)

  quizLimit        Int?    @map("quiz_limit")
  participantLimit Int?    @map("participant_limit")
  questionLimit    Int?    @map("question_limit")
  storageLimitMb   Int?    @map("storage_limit_mb")

  /// Free-text marketing bullet points shown on pricing cards — display only,
  /// never used for access control. Real entitlements live in `PlanFeature`.
  features Json @default("[]")

  description String?
  badge       String?
  color       String?
  icon        String?
  displayOrder Int     @default(0) @map("display_order")
  isActive     Boolean @default(true) @map("is_active")
  isPromoted   Boolean @default(false) @map("is_promoted")
  trialDays    Int?    @map("trial_days")

  /// Optional commercial window — a plan can be scheduled (e.g. a launch
  /// promo) without code changes; outside this window it's excluded from
  /// public pricing surfaces but still valid for existing subscribers.
  availableFrom  DateTime? @map("available_from")
  availableUntil DateTime? @map("available_until")

  /// Auto-applied promotional pricing (no code required) — when set and not
  /// expired, checkout charges `promoPrice` instead of `price` and pricing
  /// surfaces show a strikethrough. Distinct from `Coupon`, which requires
  /// the buyer to enter a code.
  promoPrice  Int?      @map("promo_price")
  promoEndsAt DateTime? @map("promo_ends_at")

  planFeatures  PlanFeature[]
  subscriptions Subscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

/// Feature Gate's source of truth: every access decision must resolve through
/// this table (via lib/services/feature-gate.ts), never by comparing a plan
/// slug/name directly — see Prompt-Archi.md "FEATURE GATE".
enum FeatureKey {
  AI_GENERATION
  AI_IMPORT
  QUESTION_BANK
  CERTIFICATES
  EXPORT_PDF
  EXPORT_EXCEL
  EXPORT_CSV
  ADVANCED_ANALYTICS
  CUSTOM_BRANDING
  CUSTOM_DOMAIN
  WEBHOOKS
  API_ACCESS
  MULTI_TEAM
  LIVE_MONITORING
  EMAIL_NOTIFICATIONS
  SMS_NOTIFICATIONS
  WHITE_LABEL
}

model PlanFeature {
  id      String     @id @default(cuid())
  planId  String     @map("plan_id")
  feature FeatureKey
  enabled Boolean    @default(true)
  /// Optional numeric quota for this feature on this plan (e.g. AI_GENERATION
  /// = 20 questions/month). Null = unlimited when `enabled`. Consumption
  /// tracking against this limit is a later phase (see project roadmap).
  limit   Int?

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, feature])
  @@map("plan_features")
}

/// Consumption counter against a `PlanFeature.limit` — one row per
/// organization/feature/calendar-month, incremented on use. A new month
/// starts a new row (no cron reset needed) via `getFeatureUsage`.
model FeatureUsage {
  id             String     @id @default(cuid())
  organizationId String     @map("organization_id")
  feature        FeatureKey
  /// Calendar-month bucket, e.g. "2026-07".
  period         String
  count          Int        @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, feature, period])
  @@map("feature_usage")
}

model Subscription {
  id             String @id @default(cuid())
  organizationId String @unique @map("organization_id")
  planId         String @map("plan_id")

  status    SubscriptionStatus @default(TRIALING)
  startDate DateTime           @default(now()) @map("start_date")
  endDate   DateTime?          @map("end_date")
  trialEnd  DateTime?          @map("trial_end")
  autoRenew Boolean            @default(true) @map("auto_renew")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])
  payments     Payment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  subscriptionId String? @map("subscription_id")

  /// Whole-unit amount in `currency` (XOF has no minor unit).
  amount    Int
  currency  String        @default("XOF")
  method    String?
  provider  String?
  reference String?       @unique
  status    PaymentStatus @default(PENDING)

  /// Intent data for what this payment is for, e.g. `{ "targetPlanId": "..." }`
  /// for a plan upgrade — kept generic so wallet top-ups / pass / PAYG
  /// purchases can reuse this same Payment row later without a schema change.
  metadata Json?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice      Invoice?
  walletTopUp       WalletTransaction? @relation("WalletTopUpPayment")
  couponRedemption  CouponRedemption?
  addOnPurchase     OrganizationAddOn?
  passPurchase      OrganizationPass?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, status])
  @@index([createdAt])
  @@map("payments")
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  paymentId      String        @unique @map("payment_id")
  number         String        @unique
  amount         Int
  currency       String
  status         PaymentStatus
  issuedAt       DateTime      @default(now()) @map("issued_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("invoices")
}

enum WebhookProvider {
  FEDAPAY
}

/// Generic webhook engine log (Prompt-Archi.md "WEBHOOKS") — every inbound
/// provider event is recorded here before/regardless of whether it's acted
/// on, so nothing is silently lost and events are replay-debuggable.
model WebhookEvent {
  id        String          @id @default(cuid())
  provider  WebhookProvider
  eventType String          @map("event_type")
  reference String?
  payload   Json
  processed Boolean         @default(false)
  error     String?
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([provider, reference])
  @@map("webhook_events")
}

// --- Coupons ----------------------------------------------------------------

enum CouponType {
  PERCENTAGE
  FIXED
}

/// Buyer-entered discount code — auto-applied `Plan.promoPrice` is a separate,
/// simpler mechanism (see Plan model) for when no code should be required.
model Coupon {
  id       String     @id @default(cuid())
  code     String     @unique
  type     CouponType
  /// Percentage (1-100) for PERCENTAGE, whole-unit amount for FIXED.
  value    Int
  currency String? // only meaningful for FIXED

  startsAt DateTime?
  endsAt   DateTime?

  maxRedemptions  Int?
  redemptionCount Int  @default(0)
  isActive        Boolean @default(true)

  /// Empty = applies to every plan.
  planIds String[] @default([])

  redemptions CouponRedemption[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("coupons")
}

model CouponRedemption {
  id             String @id @default(cuid())
  couponId       String @map("coupon_id")
  organizationId String @map("organization_id")
  paymentId      String @unique @map("payment_id")

  coupon       Coupon       @relation(fields: [couponId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([couponId])
  @@map("coupon_redemptions")
}

// --- Wallet -------------------------------------------------------------

enum WalletTransactionType {
  TOPUP
  SPEND
  REFUND
}

/// Independent of subscriptions (Prompt-Archi.md "WALLET") — a standing
/// credit balance an org can spend on AI/exports/participants/certificates.
model Wallet {
  id             String   @id @default(cuid())
  organizationId String   @unique @map("organization_id")
  balance        Int      @default(0)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("wallets")
}

model WalletTransaction {
  id       String                @id @default(cuid())
  walletId String                @map("wallet_id")
  type     WalletTransactionType
  /// Always positive — direction is carried by `type`.
  amount   Int
  reason   String
  paymentId String?              @unique @map("payment_id")

  wallet  Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  payment Payment? @relation("WalletTopUpPayment", fields: [paymentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

/// Super-admin-managed catalog of purchasable credit bundles.
model CreditPack {
  id           String  @id @default(cuid())
  name         String
  price        Int
  currency     String  @default("XOF")
  credits      Int
  isActive     Boolean @default(true)
  displayOrder Int     @default(0) @map("display_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("credit_packs")
}

// --- Pay-as-you-go --------------------------------------------------------

enum AddOnEffect {
  EXTRA_PARTICIPANTS
  EXTRA_QUIZZES
  EXTRA_QUESTIONS
  EXTRA_AI_GENERATIONS
  EXPORT_UNLOCK
  CERTIFICATE_UNLOCK
}

/// Super-admin-managed one-time purchase catalog (Prompt-Archi.md "PAY AS YOU
/// GO") — layered on top of a plan rather than replacing it.
model AddOnProduct {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Int
  currency    String      @default("XOF")
  effect      AddOnEffect
  /// Amount granted per purchase (e.g. 100 for "+100 participants"); null for
  /// a one-off unlock effect like EXPORT_UNLOCK that isn't a quantity.
  amount       Int?
  isActive     Boolean @default(true)
  isPromoted   Boolean @default(false)
  displayOrder Int     @default(0) @map("display_order")

  purchases OrganizationAddOn[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("addon_products")
}

model OrganizationAddOn {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  productId      String @map("product_id")
  /// Remaining consumable amount for metered add-ons (e.g. AI packs);
  /// null for non-consumable unlocks or non-metered quantity boosts.
  remaining Int?
  paymentId String? @unique @map("payment_id")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      AddOnProduct  @relation(fields: [productId], references: [id])
  payment      Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, productId])
  @@map("organization_addons")
}

// --- Pass -----------------------------------------------------------------

/// Super-admin-managed time-boxed feature bundle (Prompt-Archi.md "PASS").
model Pass {
  id           String       @id @default(cuid())
  name         String
  description  String?
  price        Int
  currency     String       @default("XOF")
  durationDays Int          @map("duration_days")
  features     FeatureKey[] @default([])
  isActive     Boolean      @default(true)
  isPromoted   Boolean      @default(false)
  displayOrder Int          @default(0) @map("display_order")

  purchases OrganizationPass[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("passes")
}

model OrganizationPass {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  passId         String   @map("pass_id")
  expiresAt      DateTime @map("expires_at")
  paymentId      String?  @unique @map("payment_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pass         Pass         @relation(fields: [passId], references: [id])
  payment      Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, expiresAt])
  @@map("organization_passes")
}

// --- Audit log ------------------------------------------------------------

enum AuditAction {
  ORGANIZATION_CREATED
  QUIZ_CREATED
  QUIZ_PUBLISHED
  QUIZ_ARCHIVED
  QUIZ_DUPLICATED
  QUIZ_DELETED
  PLATFORM_SETTINGS_UPDATED
  PAYMENT_SUCCEEDED
  SUBSCRIPTION_UPGRADED
}

// --- Platform settings ------------------------------------------------------

/// Singleton row (fixed id) holding platform-wide configuration editable from
/// /admin/settings — maintenance mode, feature flags, notification routing.
model PlatformSettings {
  id String @id @default("singleton")

  maintenanceMode    Boolean @default(false) @map("maintenance_mode")
  maintenanceMessage String? @map("maintenance_message")

  allowSignups   Boolean @default(true) @map("allow_signups")
  aiGeneration   Boolean @default(true) @map("ai_generation_enabled")
  exportsEnabled Boolean @default(true) @map("exports_enabled")
  billingEnabled Boolean @default(false) @map("billing_enabled")

  notificationEmail       String?  @map("notification_email")
  notifyOnNewOrganization Boolean  @default(false) @map("notify_on_new_organization")
  notifyOnNewSubscription Boolean  @default(false) @map("notify_on_new_subscription")

  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("platform_settings")
}

model AuditLog {
  id             String @id @default(cuid())
  organizationId String? @map("organization_id")
  userId         String? @map("user_id")

  action   AuditAction
  resource Json?

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

