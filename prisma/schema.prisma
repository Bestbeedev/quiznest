// Prisma schema — Phase 1 (Foundation): organizations, users, membership/RBAC.
// Phase 3 (Quiz & Questions) added below. Participants/results/etc. remain for later phases
// (see cahier des charges).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum MemberRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  MANAGER
  EDITOR
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model Organization {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  logo        String?
  banner      String?

  country String?
  city    String?
  address String?
  phone   String?
  email   String?
  website String?

  timezone String @default("UTC")
  language String @default("fr")
  currency String @default("XOF")

  subdomain    String? @unique
  customDomain String? @unique @map("custom_domain")

  settings Json               @default("{}")
  status   OrganizationStatus @default(TRIAL)

  members OrganizationMember[]
  quizzes Quiz[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([status])
  @@index([createdAt])
  @@map("organizations")
}

model User {
  id            String  @id @default(cuid())
  // `name` is required by Better Auth's core User model; firstName/lastName
  // remain our own domain fields (kept in sync at signup).
  name          String
  firstName     String  @map("first_name")
  lastName      String  @map("last_name")
  email         String  @unique
  emailVerified Boolean @default(false) @map("email_verified")
  phone         String?

  image     String?
  lastLogin DateTime? @map("last_login")
  lastIp    String?   @map("last_ip")

  timezone    String     @default("UTC")
  language    String     @default("fr")
  status      UserStatus @default(ACTIVE)
  preferences Json       @default("{}")

  twoFAEnabled Boolean @default(false) @map("two_fa_enabled")
  twoFASecret  String? @map("two_fa_secret")

  /// Platform-level role — grants access to the /admin space, independent of any
  /// organization membership. Not exposed anywhere in the UI yet; must be set directly
  /// in the database for the first super admin.
  isSuperAdmin Boolean @default(false) @map("is_super_admin")

  memberships OrganizationMember[]
  quizzes     Quiz[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  sessions Session[]
  accounts Account[]

  @@index([status])
  @@map("users")
}

model OrganizationMember {
  id             String     @id @default(cuid())
  userId         String     @map("user_id")
  organizationId String     @map("organization_id")
  role           MemberRole @default(VIEWER)
  permissions    Json       @default("[]")

  invitedBy        String?          @map("invited_by")
  invitationStatus InvitationStatus @default(ACCEPTED) @map("invitation_status")

  joinedAt DateTime @default(now()) @map("joined_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

model Quiz {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  authorId       String @map("author_id")

  title       String
  slug        String
  description String?

  timeLimit      Int?    @map("time_limit")
  passingScore   Int     @default(50) @map("passing_score")
  attempts       Int     @default(1)
  randomOrder    Boolean @default(false) @map("random_order")
  shuffleChoices Boolean @default(false) @map("shuffle_choices")
  fullscreen     Boolean @default(false)
  accessCode     String? @map("access_code")

  status      QuizStatus @default(DRAFT)
  publishedAt DateTime?  @map("published_at")
  archivedAt  DateTime?  @map("archived_at")
  openDate    DateTime?  @map("open_date")
  closeDate   DateTime?  @map("close_date")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  questions    Question[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("quizzes")
}

model Question {
  id     String @id @default(cuid())
  quizId String @map("quiz_id")

  title       String
  type        QuestionType       @default(SINGLE_CHOICE)
  difficulty  QuestionDifficulty @default(MEDIUM)
  order       Int
  points      Int                @default(1)
  timeLimit   Int?               @map("time_limit")
  hint        String?
  explanation String?

  quiz    Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  choices QuestionChoice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([quizId, order])
  @@map("questions")
}

model QuestionChoice {
  id         String @id @default(cuid())
  questionId String @map("question_id")

  text      String
  order     Int
  isCorrect Boolean @default(false) @map("is_correct")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, order])
  @@map("question_choices")
}

// --- Better Auth models below this line are generated by:
//   pnpm exec @better-auth/cli generate
// Do not hand-edit; re-run the generator instead when auth config changes.

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
