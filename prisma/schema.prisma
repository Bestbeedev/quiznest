// Prisma schema — Phase 1 (Foundation): organizations, users, membership/RBAC.
// Phase 3 (Quiz & Questions) added below. Participants/results/etc. remain for later phases
// (see cahier des charges).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum MemberRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  MANAGER
  EDITOR
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model Organization {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  logo        String?
  banner      String?

  country String?
  city    String?
  address String?
  phone   String?
  email   String?
  website String?

  timezone String @default("UTC")
  language String @default("fr")
  currency String @default("XOF")

  subdomain    String? @unique
  customDomain String? @unique @map("custom_domain")

  settings Json               @default("{}")
  status   OrganizationStatus @default(TRIAL)

  members OrganizationMember[]
  quizzes Quiz[]

  subscription Subscription?
  payments     Payment[]
  auditLogs    AuditLog[]
  invitations  Invitation[]
  apiKeys      ApiKey[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([status])
  @@index([createdAt])
  @@map("organizations")
}

model User {
  id            String  @id @default(cuid())
  // `name` is required by Better Auth's core User model; firstName/lastName
  // remain our own domain fields (kept in sync at signup).
  name          String
  firstName     String  @map("first_name")
  lastName      String  @map("last_name")
  email         String  @unique
  emailVerified Boolean @default(false) @map("email_verified")
  phone         String?

  image     String?
  lastLogin DateTime? @map("last_login")
  lastIp    String?   @map("last_ip")

  timezone    String     @default("UTC")
  language    String     @default("fr")
  status      UserStatus @default(ACTIVE)
  preferences Json       @default("{}")

  twoFAEnabled Boolean @default(false) @map("two_fa_enabled")
  twoFASecret  String? @map("two_fa_secret")

  /// Platform-level role — grants access to the /admin space, independent of any
  /// organization membership. Not exposed anywhere in the UI yet; must be set directly
  /// in the database for the first super admin.
  isSuperAdmin Boolean @default(false) @map("is_super_admin")

  memberships     OrganizationMember[]
  quizzes         Quiz[]
  auditLogs       AuditLog[]
  sentInvitations Invitation[]
  createdApiKeys  ApiKey[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  sessions Session[]
  accounts Account[]

  @@index([status])
  @@map("users")
}

model OrganizationMember {
  id             String     @id @default(cuid())
  userId         String     @map("user_id")
  organizationId String     @map("organization_id")
  role           MemberRole @default(VIEWER)
  permissions    Json       @default("[]")

  invitedBy        String?          @map("invited_by")
  invitationStatus InvitationStatus @default(ACCEPTED) @map("invitation_status")

  joinedAt DateTime @default(now()) @map("joined_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

/// A pending invite to join an organization, keyed by email rather than
/// userId — the invitee may not have an account yet. No email is sent (no
/// email provider is wired in this project); the invite is a shareable link
/// with a token, accepted at /invite/[token].
model Invitation {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  email          String
  role           MemberRole       @default(VIEWER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedBy      String           @map("invited_by")
  expiresAt      DateTime         @map("expires_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@map("invitations")
}

/// Storage/management only — no API route currently authenticates requests
/// with these keys (no public API exists yet, see roadmap Phase 8). Only the
/// hash is stored; the full key is shown once at creation time.
model ApiKey {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  name           String
  keyPrefix      String    @map("key_prefix")
  keyHash        String    @map("key_hash")
  lastUsedAt     DateTime? @map("last_used_at")
  createdBy      String    @map("created_by")
  revokedAt      DateTime? @map("revoked_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@map("api_keys")
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

model Quiz {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  authorId       String @map("author_id")

  title       String
  slug        String
  description String?

  timeLimit       Int?    @map("time_limit")
  passingScore    Int     @default(50) @map("passing_score")
  attempts        Int     @default(1)
  randomOrder     Boolean @default(false) @map("random_order")
  shuffleChoices  Boolean @default(false) @map("shuffle_choices")
  fullscreen      Boolean @default(false)
  accessCode      String? @unique @map("access_code")
  showCorrections Boolean @default(true) @map("show_corrections")

  status      QuizStatus @default(DRAFT)
  publishedAt DateTime?  @map("published_at")
  archivedAt  DateTime?  @map("archived_at")
  openDate    DateTime?  @map("open_date")
  closeDate   DateTime?  @map("close_date")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  questions    Question[]
  participants Participant[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("quizzes")
}

model Question {
  id     String @id @default(cuid())
  quizId String @map("quiz_id")

  title       String
  type        QuestionType       @default(SINGLE_CHOICE)
  difficulty  QuestionDifficulty @default(MEDIUM)
  order       Int
  points      Int                @default(1)
  timeLimit   Int?               @map("time_limit")
  hint        String?
  explanation String?

  /// Free-text subject grouping (e.g. "Mathématiques") — no separate category
  /// taxonomy/CRUD exists yet, this is deliberately a plain field until one does.
  category String?
  tags     String[] @default([])

  quiz    Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  choices QuestionChoice[]
  answers Answer[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([quizId, order])
  @@map("questions")
}

model QuestionChoice {
  id         String @id @default(cuid())
  questionId String @map("question_id")

  text      String
  order     Int
  isCorrect Boolean @default(false) @map("is_correct")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, order])
  @@map("question_choices")
}

enum ParticipantStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model Participant {
  id     String @id @default(cuid())
  quizId String @map("quiz_id")

  name  String
  email String?

  attempt    Int               @default(1)
  status     ParticipantStatus @default(IN_PROGRESS)
  score      Int               @default(0)
  percentage Float             @default(0)
  passed     Boolean           @default(false)

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  timeSpent   Int?      @map("time_spent")

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([quizId, status])
  @@index([quizId, email])
  @@map("participants")
}

model Answer {
  id            String   @id @default(cuid())
  participantId String   @map("participant_id")
  questionId    String   @map("question_id")
  choiceIds     String[] @map("choice_ids")

  isCorrect Boolean @default(false) @map("is_correct")
  score     Int     @default(0)
  /// Seconds spent on this question — null for answers submitted before this
  /// was tracked, or if the client didn't report it. Not backfillable.
  timeSpent Int?    @map("time_spent")

  createdAt DateTime @default(now()) @map("created_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([participantId, questionId])
  @@map("answers")
}

// --- Billing (Phase 7 groundwork) ---------------------------------------
// Minimal schema to back the super admin dashboard (subscriptions/payments/
// revenue). No payment provider is wired yet — Payment rows will only start
// appearing once FedaPay integration lands; Subscription rows exist from day
// one because every organization is auto-enrolled on the Free plan at creation.

enum PlanInterval {
  MONTH
  YEAR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Plan {
  id       String       @id @default(cuid())
  name     String
  slug     String       @unique
  /// Whole-unit amount in `currency` (XOF has no minor unit). Null = pricing not yet defined (sur devis).
  price    Int?
  currency String       @default("XOF")
  interval PlanInterval @default(MONTH)

  quizLimit        Int?    @map("quiz_limit")
  participantLimit Int?    @map("participant_limit")
  questionLimit    Int?    @map("question_limit")
  storageLimitMb   Int?    @map("storage_limit_mb")

  features Json @default("[]")

  subscriptions Subscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

model Subscription {
  id             String @id @default(cuid())
  organizationId String @unique @map("organization_id")
  planId         String @map("plan_id")

  status    SubscriptionStatus @default(TRIALING)
  startDate DateTime           @default(now()) @map("start_date")
  endDate   DateTime?          @map("end_date")
  trialEnd  DateTime?          @map("trial_end")
  autoRenew Boolean            @default(true) @map("auto_renew")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])
  payments     Payment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  subscriptionId String? @map("subscription_id")

  /// Whole-unit amount in `currency` (XOF has no minor unit).
  amount    Int
  currency  String        @default("XOF")
  method    String?
  provider  String?
  reference String?       @unique
  status    PaymentStatus @default(PENDING)

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, status])
  @@index([createdAt])
  @@map("payments")
}

// --- Audit log ------------------------------------------------------------

enum AuditAction {
  ORGANIZATION_CREATED
  QUIZ_CREATED
  QUIZ_PUBLISHED
  QUIZ_ARCHIVED
  QUIZ_DUPLICATED
  QUIZ_DELETED
  PLATFORM_SETTINGS_UPDATED
}

// --- Platform settings ------------------------------------------------------

/// Singleton row (fixed id) holding platform-wide configuration editable from
/// /admin/settings — maintenance mode, feature flags, notification routing.
model PlatformSettings {
  id String @id @default("singleton")

  maintenanceMode    Boolean @default(false) @map("maintenance_mode")
  maintenanceMessage String? @map("maintenance_message")

  allowSignups   Boolean @default(true) @map("allow_signups")
  aiGeneration   Boolean @default(true) @map("ai_generation_enabled")
  exportsEnabled Boolean @default(true) @map("exports_enabled")
  billingEnabled Boolean @default(false) @map("billing_enabled")

  notificationEmail       String?  @map("notification_email")
  notifyOnNewOrganization Boolean  @default(false) @map("notify_on_new_organization")
  notifyOnNewSubscription Boolean  @default(false) @map("notify_on_new_subscription")

  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("platform_settings")
}

model AuditLog {
  id             String @id @default(cuid())
  organizationId String? @map("organization_id")
  userId         String? @map("user_id")

  action   AuditAction
  resource Json?

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

// --- Better Auth models below this line are generated by:
//   pnpm exec @better-auth/cli generate
// Do not hand-edit; re-run the generator instead when auth config changes.

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
